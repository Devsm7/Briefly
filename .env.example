# ── Database ──────────────────────────────────────────────
POSTGRES_USER=briefly
POSTGRES_PASSWORD=briefly_secret
POSTGRES_DB=briefly_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://briefly:briefly_secret@db:5432/briefly_db

# ── Backend ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM (Ollama) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# Optional: OpenAI fallback (leave blank to use Ollama only)
OPENAI_API_KEY=

# ── News Scraper ───────────────────────────────────────────
# Optional: NewsAPI key for enhanced coverage
# Get free key at https://newsapi.org/
NEWS_API_KEY=

# ── Scheduler ─────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
